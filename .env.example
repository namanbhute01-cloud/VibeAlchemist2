# ═══════════════════════════════════════════════════════════════
# VIBE ALCHEMIST V2 - Environment Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# API Server Configuration
# ───────────────────────────────────────────────────────────────
# Host address (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# Port number (8081 to avoid conflict with HRMS on 5000)
API_PORT=8081

# Debug mode (false for production)
DEBUG=false

# ───────────────────────────────────────────────────────────────
# Camera Configuration
# ───────────────────────────────────────────────────────────────
# Camera sources (comma-separated)
# Examples:
#   0                                    - Default webcam
#   0,rtsp://camera-ip/stream           - Multiple cameras
#   http://192.168.1.100:8080/video     - IP camera
CAMERA_SOURCES=0

# Target video height (resolution)
TARGET_HEIGHT=720

# Maximum frames per second
FRAME_RATE_LIMIT=15

# ───────────────────────────────────────────────────────────────
# Vision & AI Configuration
# ───────────────────────────────────────────────────────────────
# Directory containing ONNX models
MODELS_DIR=models

# Face detection confidence (0.0 - 1.0)
FACE_DETECTION_CONF=0.5

# Person detection confidence (0.0 - 1.0)
PERSON_DETECTION_CONF=0.4

# Face similarity threshold for matching (0.0 - 1.0)
FACE_SIMILARITY_THRESHOLD=0.65

# ───────────────────────────────────────────────────────────────
# Face Storage & Google Drive
# ───────────────────────────────────────────────────────────────
# Temporary directory for face captures
FACE_TEMP_DIR=temp_faces

# Google Drive folder ID (optional, for cloud backup)
# Leave empty to disable Drive upload
GDRIVE_FOLDER_ID=

# Google Drive credentials file
GDRIVE_CREDENTIALS_FILE=credentials.json

# Upload interval in seconds (900 = 15 minutes)
DRIVE_UPLOAD_INTERVAL=900

# ───────────────────────────────────────────────────────────────
# Music Player Configuration
# ───────────────────────────────────────────────────────────────
# Directory containing music files
ROOT_MUSIC_DIR=./OfflinePlayback

# Default volume (0 - 100)
DEFAULT_VOLUME=70

# Enable shuffle mode
SHUFFLE_MODE=true

# ───────────────────────────────────────────────────────────────
# Performance Tuning
# ───────────────────────────────────────────────────────────────
# Number of threads for OpenMP
OMP_NUM_THREADS=1

# NNPACK limit (0 = disabled)
NNPACK_LIMIT=0
