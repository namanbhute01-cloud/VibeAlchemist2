# ═══════════════════════════════════════════════════════════════
# VIBE ALCHEMIST V2 - Environment Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# API Server Configuration
# ───────────────────────────────────────────────────────────────
# Host address (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# Port number (8000 — standard port, avoids conflict with HRMS on 5000)
API_PORT=8000

# Debug mode (false for production)
DEBUG=false

# ───────────────────────────────────────────────────────────────
# Camera Configuration
# ───────────────────────────────────────────────────────────────
# Camera sources (comma-separated)
# Examples:
#   0                                    - Default webcam
#   0,rtsp://camera-ip/stream           - Multiple cameras
#   http://192.168.1.100:8080/video     - IP camera
CAMERA_SOURCES=0

# Target video height (resolution)
TARGET_HEIGHT=720

# Maximum frames per second
FRAME_RATE_LIMIT=15

# ───────────────────────────────────────────────────────────────
# Vision & AI Configuration
# ───────────────────────────────────────────────────────────────
# Directory containing ONNX models
MODELS_DIR=models

# Face detection confidence (0.0 - 1.0)
FACE_DETECTION_CONF=0.5

# Person detection confidence (0.0 - 1.0)
PERSON_DETECTION_CONF=0.4

# Face similarity threshold for matching (0.0 - 1.0)
FACE_SIMILARITY_THRESHOLD=0.65

# ───────────────────────────────────────────────────────────────
# Face Storage & Google Drive
# ───────────────────────────────────────────────────────────────
# Temporary directory for face captures
FACE_TEMP_DIR=temp_faces

# Google Drive folder ID (optional, for cloud backup)
# Leave empty to disable Drive upload
GDRIVE_FOLDER_ID=

# Google Drive credentials file
GDRIVE_CREDENTIALS_FILE=credentials.json

# Upload interval in seconds (900 = 15 minutes)
DRIVE_UPLOAD_INTERVAL=900

# ───────────────────────────────────────────────────────────────
# Music Player Configuration
# ───────────────────────────────────────────────────────────────
# Directory containing music files
ROOT_MUSIC_DIR=./OfflinePlayback

# Default volume (0 - 100)
DEFAULT_VOLUME=70

# Enable shuffle mode
SHUFFLE_MODE=true

# ───────────────────────────────────────────────────────────────
# UI Settings (persisted from Settings page)
# ───────────────────────────────────────────────────────────────
# Auto-adjust playlist based on age detection
AUTO_PLAYLIST=true

# Show face detection overlay on camera feeds
FACE_OVERLAY=true

# Privacy mode (blur faces in dashboard)
PRIVACY_MODE=false

# ───────────────────────────────────────────────────────────────
# Performance Tuning
# ───────────────────────────────────────────────────────────────
# Number of threads for OpenMP
OMP_NUM_THREADS=1

# NNPACK limit (0 = disabled)
NNPACK_LIMIT=0

# ═══════════════════════════════════════════════════════════════
# VIBE ALCHEMIST V4 — New Tiered Pipeline Settings
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Tiered Detection
# ───────────────────────────────────────────────────────────────
# Downscale height for fast detection (pixels)
DETECTION_SCALE=240

# Run heavy models every N frames (3 = ~5 FPS at 15 FPS target)
INFERENCE_EVERY_N_FRAMES=5

# Re-confirm identity every N frames (30 = ~0.5 FPS)
IDENTITY_EVERY_N_FRAMES=30

# Skip inference if all bboxes unchanged (IoU threshold)
MOTION_GATE_IOU=0.90

# ───────────────────────────────────────────────────────────────
# Model Paths (V5 Upgrade Models)
# ───────────────────────────────────────────────────────────────
# RetinaFace — robust face detection (profile views, occlusion)
RETINAFACE_MODEL=models/retinaface_mobilenet_int8.onnx

# Face detection confidence threshold (0.0 - 1.0)
FACE_DETECTION_CONF=0.5

# Face NMS threshold for RetinaFace (0.0 - 1.0)
FACE_NMS_THRESHOLD=0.4

# MiVOLO XX-Small — age + gender estimation
MIVOLO_MODEL=models/mivolo_xxs.onnx

# YOLOv8n-face — fallback face detector
YOLO_FACE_MODEL=models/yolov8n-face.pt

# MobileNet FER INT8 — emotion recognition
FER_MODEL=models/mobilenet_fer_int8.onnx

# ───────────────────────────────────────────────────────────────
# Kalman Age Smoothing
# ───────────────────────────────────────────────────────────────
# Process noise — how much we expect age to change naturally
KALMAN_PROCESS_NOISE=1.0

# Smoothing factor — higher = trust new predictions more
KALMAN_ALPHA=0.2

# ───────────────────────────────────────────────────────────────
# V5 ADAPTIVE TIER (Auto-detected, or set 1/2/3 to force)
# ───────────────────────────────────────────────────────────────
# Leave blank for auto-detect (runs hardware benchmark on startup)
# Set to 1=LOW, 2=MEDIUM, 3=HIGH to override
FORCE_TIER=

# Model paths per tier
EDGEFACE_XXS_MODEL=models/edgeface_xxs_int8.onnx
EDGEFACE_XS_MODEL=models/edgeface_xs_int8.onnx
EDGEFACE_BASE_MODEL=models/edgeface_base_int8.onnx
MIVOLO_XXS_MODEL=models/mivolo_xxs.onnx
MIVOLO_FULL_MODEL=models/mivolo_full.onnx
FER_MODEL=models/mobilenet_fer_int8.onnx

# ───────────────────────────────────────────────────────────────
# Emotion Smoothing
# ───────────────────────────────────────────────────────────────
# Number of frames for emotion rolling average
EMOTION_SMOOTHING_FRAMES=5

# ───────────────────────────────────────────────────────────────
# Fuzzy Vibe Logic
# ───────────────────────────────────────────────────────────────
# Min confidence to trust demographic result
FUZZY_CONFIDENCE_MIN=0.65

# Recognized person overrides fuzzy output
KNOWN_PERSON_PRIORITY=true

# ───────────────────────────────────────────────────────────────
# Audio LUFS Normalization
# ───────────────────────────────────────────────────────────────
# Target loudness (LUFS) — EBU R128 standard
LUFS_TARGET=-14.0

# File extension for LUFS sidecar files
LUFS_SIDECAR_EXT=.lufs
