# --- API SERVER CONFIG ---
API_HOST=0.0.0.0
API_PORT=8081
DEBUG=true

# --- CAMERA CONFIG ---
CAMERA_SOURCES=0,http://192.168.29.173:8080/video , http://192.168.29.101:5000/video
TARGET_HEIGHT=720
FRAME_RATE_LIMIT=15

# --- VISION & MODELS ---
MODELS_DIR=models
FACE_DETECTION_CONF=0.5
PERSON_DETECTION_CONF=0.4
FACE_SIMILARITY_THRESHOLD=0.65

# --- FACE VAULT & STORAGE ---
FACE_TEMP_DIR=temp_faces
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here
GDRIVE_CREDENTIALS_FILE=credentials.json
DRIVE_UPLOAD_INTERVAL=900

# --- MUSIC PLAYER ---
ROOT_MUSIC_DIR=./OfflinePlayback
DEFAULT_VOLUME=70
SHUFFLE_MODE=true

# --- PERFORMANCE TUNING ---
OMP_NUM_THREADS=1
NNPACK_LIMIT=0
